---
interface Props {
  title: string;
  sourceUrl: string;
  text: string;
  outboundLinks: string[];
  documentLinks: string[];
  videoLinks: string[];
  imageLinks: string[];
}

const { title, sourceUrl, text, outboundLinks = [], documentLinks = [], videoLinks = [], imageLinks = [] } = Astro.props;

const textLines = text
  .split("\n")
  .map((line) => line.trim())
  .filter(Boolean);
---

<section class="section">
  <div class="container card box">
    <p class="kicker">Legacy Page Mirror</p>
    <h1 class="page-title">{title.replace(/^Kaleo Church: Anchorage, AK\s*>\s*/i, "")}</h1>
    <p class="lead">Source: <a href={sourceUrl} target="_blank" rel="noreferrer">{sourceUrl}</a></p>
  </div>
</section>

<section class="section">
  <div class="container card box">
    <h2>Page Text</h2>
    <div class="copy">
      {textLines.map((line) => <p>{line}</p>)}
    </div>
  </div>
</section>

{videoLinks.length > 0 && (
  <section class="section">
    <div class="container card box">
      <h2>Video Links</h2>
      <ul>
        {videoLinks.map((href) => <li><a href={href} target="_blank" rel="noreferrer">{href}</a></li>)}
      </ul>
    </div>
  </section>
)}

{imageLinks.length > 0 && (
  <section class="section">
    <div class="container card box">
      <h2>Images</h2>
      <div class="img-grid">
        {imageLinks.map((href) => (
          <a href={href} target="_blank" rel="noreferrer">
            <img src={href} alt="Legacy page image" loading="lazy" />
          </a>
        ))}
      </div>
    </div>
  </section>
)}

{documentLinks.length > 0 && (
  <section class="section">
    <div class="container card box">
      <h2>Document Links</h2>
      <ul>
        {documentLinks.map((href) => <li><a href={href} target="_blank" rel="noreferrer">{href}</a></li>)}
      </ul>
    </div>
  </section>
)}

{outboundLinks.length > 0 && (
  <section class="section">
    <div class="container card box">
      <h2>Outbound Links</h2>
      <ul>
        {outboundLinks.map((href) => <li><a href={href} target="_blank" rel="noreferrer">{href}</a></li>)}
      </ul>
    </div>
  </section>
)}

<style>
  .box { padding: 1.2rem; }
  .copy p { margin: 0 0 0.65rem; }
  .img-grid {
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  }
  .img-grid a {
    display: block;
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
  }
  .img-grid img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
  }
  ul { margin: 0; padding-left: 1rem; }
  li { margin-bottom: 0.35rem; }
</style>
