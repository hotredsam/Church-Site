---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---
<BaseLayout title="What We Believe | Kaleo Church">
  <PageHeader title="What We Believe" intro="Our doctrine and practice are rooted in Scripture, centered on the gospel, and directed toward discipleship and church multiplication." />
  <section class="section"><div class="container card" style="padding:1.2rem">
    <h2>Core Convictions</h2>
    <ul>
      <li>Jesus Christ is Lord, crucified and risen, and the only hope for salvation.</li>
      <li>The Bible is God’s authoritative Word for faith and life.</li>
      <li>The church exists to make disciples and send workers to all nations.</li>
    </ul>
  </div></section>
</BaseLayout>
