---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---
<BaseLayout title="Plan Your Visit | Kaleo Church">
  <PageHeader title="Plan Your Visit" intro="Services begin at 10:00 AM every Sunday. You can expect worship through music and teaching from the Bible." />
  <section class="section"><div class="container card" style="padding:1.2rem">
    <h2>Locations</h2>
    <p>We gather in Midtown and South Anchorage. If you are planning your first Sunday, use our connect form and our team will help you prepare.</p>
    <p><a class="btn btn-primary" href="/get-connected/contact-connect-card">Fill Out Connect Card</a></p>
  </div></section>
</BaseLayout>
