---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---
<BaseLayout title="Car Maintenance Help | Kaleo Church">
  <PageHeader title="Car Maintenance Help" intro="Need help with vehicle maintenance? Submit a request and our team will coordinate with men in the church who can help." />

  <section class="section">
    <div class="container card box">
      <form id="car-help-form" class="form-grid">
        <label>Full Name<input required name="name" /></label>
        <label>Email<input required type="email" name="email" /></label>
        <label>Phone<input required name="phone" /></label>
        <label>Vehicle (Year/Make/Model)<input required name="vehicle" /></label>
        <label>Issue Summary<textarea required name="issue" rows="4"></textarea></label>
        <label>Urgency
          <select name="urgency">
            <option>Low</option>
            <option>Medium</option>
            <option>High</option>
          </select>
        </label>
        <label>Preferred Days/Times<textarea name="availability" rows="2"></textarea></label>
        <label><input type="checkbox" required name="consent" /> I agree to be contacted by church volunteers.</label>
        <button class="btn btn-primary" type="submit">Submit Request</button>
      </form>
      <p id="status" class="lead"></p>
    </div>
  </section>

  <section class="section">
    <div class="container card box">
      <h2>How This Works</h2>
      <ol>
        <li>Your request is saved in your browser and prepared for email delivery to the church.</li>
        <li>After submitting, your email app opens with the request details addressed to <code>info@kaleoalaska.org</code>.</li>
        <li>The team can also view submissions from the Team Portal on this device.</li>
      </ol>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const form = document.getElementById("car-help-form");
  const status = document.getElementById("status");
  const key = "kaleo_car_help_requests";

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const data = Object.fromEntries(fd.entries());
    data.createdAt = new Date().toISOString();

    const existing = JSON.parse(localStorage.getItem(key) || "[]");
    existing.push(data);
    localStorage.setItem(key, JSON.stringify(existing));

    const subject = encodeURIComponent(`Car Maintenance Help Request - ${data.name || "New Request"}`);
    const body = encodeURIComponent(
      `Name: ${data.name}\nEmail: ${data.email}\nPhone: ${data.phone}\nVehicle: ${data.vehicle}\nIssue: ${data.issue}\nUrgency: ${data.urgency}\nAvailability: ${data.availability || "N/A"}\nSubmitted: ${data.createdAt}`
    );

    const mailto = `mailto:info@kaleoalaska.org?subject=${subject}&body=${body}`;
    window.location.href = mailto;

    form.reset();
    status.textContent = "Request saved and email draft opened.";
  });
</script>

<style>
  .box { padding: 1.2rem; }
  .form-grid { display: grid; gap: 0.75rem; }
  label { display: grid; gap: 0.3rem; font-weight: 600; }
  input, textarea, select {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.55rem 0.65rem;
    font: inherit;
  }
  ol { margin: 0; padding-left: 1rem; }
</style>
